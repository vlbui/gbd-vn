# Raw data — IHME license, not redistributable; large
raw_data/burden/*.csv
raw_data/covariates/*.csv
raw_data/covariates/*.XLSX
raw_data/air_pollution/**/*.zip
raw_data/air_pollution/**/*.csv
!raw_data/**/README.md
!raw_data/**/*.md

# Derived data — regenerable by running shared/pipeline/
shared_processed/*.csv
!shared_processed/README.md

# Per-project data — regenerable by the paper's pipeline
projects/*/data/*.csv

# Figure outputs — regenerate via each paper's figures script
projects/*/figures/html/
projects/*/figures/static/*.png
projects/*/figures/static/*.svg

# Manuscript binaries
projects/*/manuscript/*.docx

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
build/
dist/

# Word lockfiles / OS cruft
~$*
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/
